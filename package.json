{
  "name": "oxrls",
  "version": "0.1.0",
  "description": "Rust-powered release management for JS/TS monorepos — version bumps, changelogs, pre-release mode, and npm publishing",
  "main": "index.js",
  "bin": {
    "oxrls": "./bin/oxrls.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/napi-rs/package-template.git"
  },
  "license": "MIT",
  "keywords": [
    "release",
    "monorepo",
    "changesets",
    "versioning",
    "changelog",
    "napi-rs"
  ],
  "files": [
    "bin/",
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "oxrls-native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:cli": "cargo build --release --bin oxrls && cp target/release/oxrls bin/oxrls",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "prettier . -w",
    "format:rs": "cargo fmt",
    "format:toml": "taplo format",
    "lint": "oxlint .",
    "prepare": "husky",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "postinstall": "node scripts/postinstall.js"
  },
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.0",
    "ava": "^8.0.0",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.14.0",
    "prettier": "^3.6.2",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint --fix"
    ],
    "*.@(js|ts|tsx|yml|yaml|md|json)": [
      "prettier --write"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "ava": {
    "extensions": ["ts"],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  }
}
