{
  "name": "@bdbchgg/rivet",
  "version": "1.0.0-alpha.6",
  "bin": "./bin/rivet.js",
  "description": "Rust-powered release management for JS/TS monorepos — version bumps, changelogs, pre-release mode, and npm publishing",
  "devDependencies": {
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.2.0",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.0",
    "ava": "^8.0.0",
    "chalk": "^5.6.2",
    "npm-run-all2": "^8.0.4",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0",
    "vite-plus": "latest"
  },
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  },
  "files": [
    "bin/",
    "index.js",
    "index.d.ts"
  ],
  "keywords": [
    "release",
    "monorepo",
    "changesets",
    "versioning",
    "changelog",
    "napi-rs"
  ],
  "license": "MIT",
  "main": "index.js",
  "napi": {
    "binaryName": "rivet-native",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "optionalDependencies": {
    "@bdbchgg/rivet-darwin-arm64": "1.0.0-alpha.4",
    "@bdbchgg/rivet-darwin-x64": "1.0.0-alpha.4",
    "@bdbchgg/rivet-linux-x64-gnu": "1.0.0-alpha.4",
    "@bdbchgg/rivet-win32-x64-msvc": "1.0.0-alpha.4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/napi-rs/package-template.git"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:cli": "cargo build --release --bin rivet",
    "build:debug": "napi build --platform",
    "format": "run-p format:prettier format:rs format:toml",
    "format:prettier": "vp fmt .",
    "format:rs": "cargo fmt",
    "format:toml": "taplo format",
    "lint": "vp lint .",
    "prepare": "vp config",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava"
  }
}
